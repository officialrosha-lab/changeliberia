# Application Configuration
NODE_ENV=development
PORT=4000

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/change_liberia_dev"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# CORS Configuration
# CORS_ORIGIN and ALLOWED_ORIGINS are both read; comma-separated lists.
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
ALLOWED_ORIGINS=""
WEBSOCKET_CORS_ORIGIN=""

# App/frontend URLs (used for links in emails, share URLs, OAuth redirects)
APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
WEB_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Swagger/API Documentation
ENABLE_SWAGGER=true

# Redis (optional — enables Socket.IO Redis adapter and shared queues)
USE_REDIS_ADAPTER=false
REDIS_URL="redis://localhost:6379"

# ============================================
# STRIPE CONFIGURATION (Payment Processing)
# ============================================

# Development (Test): Use sk_test_... and whsec_test_...
# Production (Live): Use sk_live_... and whsec_...
STRIPE_API_KEY="sk_test_51234567890abcdefghijklmnopqrst"

# Stripe Webhook Configuration
# Get this from Stripe Dashboard → Developers → Webhooks → [Your Endpoint] → Signing Secret
STRIPE_WEBHOOK_SECRET="whsec_test_1234567890abcdefghijklmnopqrst"

# Stripe Settings
STRIPE_CURRENCY="USD"
SKIP_STRIPE_VALIDATION=false

# Webhook Configuration
# Timestamp tolerance in seconds (default: 300 = 5 minutes)
WEBHOOK_SIGNATURE_TOLERANCE=300

# Enable webhook debugging/logging
ENABLE_WEBHOOK_LOGGING=true

# ============================================
# MTN MoMo (Mobile Money payments)
# ============================================
MOMO_API_HOST="sandbox.momodeveloper.mtn.com"
MOMO_API_USER=""
MOMO_API_KEY=""
MOMO_TARGET_ENVIRONMENT="sandbox"
MOMO_COUNTRY="LR"
MOMO_CURRENCY="USD"
MOMO_WEBHOOK_SECRET=""
MOMO_WEBHOOK_URL=""
MOMO_POLLING_INTERVAL=5000
MOMO_POLLING_MAX_RETRIES=12

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Email Service Provider: resend | sendgrid | smtp | (unset = local dev MailHog on :1025)
EMAIL_PROVIDER="resend"
RESEND_API_KEY="re_your_resend_api_key_here"
# Verifies inbound Resend webhooks (POST /api/v1/webhooks/resend); leave empty to disable verification in dev
RESEND_WEBHOOK_SECRET=""
SENDGRID_API_KEY=""

# SMTP fallback (EMAIL_PROVIDER=smtp)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE=false

# Addresses
EMAIL_FROM="noreply@changeliberia.org"
EMAIL_REPLY_TO="support@changeliberia.org"
MAIL_FROM="noreply@changeliberia.org"
MAIL_REPLY_TO="support@changeliberia.org"

# Where POST /api/v1/feedback submissions are forwarded (falls back to EMAIL_REPLY_TO)
FEEDBACK_EMAIL=""

# Domain used in tracked email links
TRACKING_DOMAIN=""

# ============================================
# TWILIO (SMS / Phone OTP / inbound SMS signing)
# ============================================

TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Required in production — inbound SMS webhook rejects unsigned requests without it
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"
# Set true in dev to print OTPs to the console instead of sending SMS
TWILIO_CONSOLE_FALLBACK=true

# ============================================
# CAPTCHA (signature fraud gating)
# ============================================
# hcaptcha | turnstile
CAPTCHA_PROVIDER="hcaptcha"
HCAPTCHA_SECRET_KEY=""
TURNSTILE_SECRET_KEY=""

# ============================================
# GOOGLE OAUTH (social login)
# ============================================
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# ============================================
# THIRD-PARTY INTEGRATIONS
# ============================================

# Facebook SDK / Pixel / Conversions API
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"
FACEBOOK_ACCESS_TOKEN=""
FACEBOOK_API_VERSION="v19.0"
FACEBOOK_PIXEL_ID=""

# ============================================
# FILE UPLOADS
# ============================================
# Petition media (images) and ID verification documents.
# Leave *_PUBLIC_BASE_URL empty to serve through the API's authenticated routes.
PETITION_MEDIA_UPLOAD_DIR="uploads/petition-media"
PETITION_MEDIA_PUBLIC_BASE_URL=""
ID_DOCUMENT_UPLOAD_DIR="uploads/id-documents"
ID_DOCUMENT_PUBLIC_BASE_URL=""

# ============================================
# FRAUD DETECTION
# ============================================
# Risk score above which admins are alerted
FRAUD_RISK_ALERT_THRESHOLD=75

# ============================================
# Web Push Notifications (browser Push API)
# ============================================
# Generate a keypair with: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY="your_vapid_public_key_here"
VAPID_PRIVATE_KEY="your_vapid_private_key_here"
VAPID_SUBJECT="mailto:support@changelib.org"

# ============================================
# NOTES
# ============================================

# Development Tips:
# 1. Get Stripe keys from: https://dashboard.stripe.com/settings/api-keys
# 2. Get Webhook Secret from: https://dashboard.stripe.com/webhooks
# 3. For local Stripe testing, use: stripe listen --forward-to localhost:4000/api/v1/payments/webhook
# 4. Test keys start with sk_test_ and pk_test_
# 5. Live keys start with sk_live_ and pk_live_
# 6. Never commit actual .env file to git (it's in .gitignore)
# 7. In production, use environment variables from deployment platform (Docker, Kubernetes, etc.)
