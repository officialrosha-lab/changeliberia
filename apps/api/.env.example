# Application Configuration
NODE_ENV=development
PORT=4000

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/change_liberia_dev"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION=86400

# CORS Configuration
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Swagger/API Documentation
ENABLE_SWAGGER=true

# ============================================
# STRIPE CONFIGURATION (Payment Processing)
# ============================================

# Stripe API Keys
# Development (Test): Use sk_test_... and whsec_test_...
# Production (Live): Use sk_live_... and whsec_...
STRIPE_API_KEY="sk_test_51234567890abcdefghijklmnopqrst"
STRIPE_PUBLISHABLE_KEY="pk_test_51234567890abcdefghijklmnopqrst"

# Stripe Webhook Configuration
# Get this from Stripe Dashboard → Developers → Webhooks → [Your Endpoint] → Signing Secret
STRIPE_WEBHOOK_SECRET="whsec_test_1234567890abcdefghijklmnopqrst"

# Stripe Settings
STRIPE_CURRENCY="USD"

# Webhook Configuration
# Timestamp tolerance in seconds (default: 300 = 5 minutes)
WEBHOOK_SIGNATURE_TOLERANCE=300

# Enable webhook debugging/logging
ENABLE_WEBHOOK_LOGGING=true

# ============================================
# EMAIL CONFIGURATION (Notifications)
# ============================================

# Email Service Provider (sendgrid, mailgun, etc.)
EMAIL_PROVIDER="sendgrid"
EMAIL_API_KEY="SG.your_sendgrid_api_key_here"

# From Email Address
EMAIL_FROM="noreply@changeliberia.org"

# ============================================
# ANALYTICS CONFIGURATION
# ============================================

# Google Analytics / Mixpanel / Custom Analytics
ANALYTICS_PROVIDER="google"
ANALYTICS_KEY="G-XXXXXXXXXX"

# ============================================
# THIRD-PARTY INTEGRATIONS
# ============================================

# Facebook SDK
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"

# Government API (Liberian verification)
GOVERNMENT_API_URL="https://api.example.gov.lr"
GOVERNMENT_API_KEY="your_government_api_key"

# ============================================
# LOGGING & MONITORING
# ============================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Sentry (Error Tracking)
SENTRY_DSN=""

# ============================================
# DEVELOPMENT-ONLY SETTINGS
# ============================================

# Debug Mode
DEBUG=false

# Seed Database on Startup
SEED_DATABASE=false

# ============================================
# NOTES
# ============================================

# Development Tips:
# 1. Get Stripe keys from: https://dashboard.stripe.com/settings/api-keys
# 2. Get Webhook Secret from: https://dashboard.stripe.com/webhooks
# 3. For local Stripe testing, use: stripe listen --forward-to localhost:4000/api/v1/payments/webhook
# 4. Test keys start with sk_test_ and pk_test_
# 5. Live keys start with sk_live_ and pk_live_
# 6. Never commit actual .env file to git (it's in .gitignore)
# 7. In production, use environment variables from deployment platform (Docker, Kubernetes, etc.)
