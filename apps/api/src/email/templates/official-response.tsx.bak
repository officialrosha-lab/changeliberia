import {
  Body,
  Button,
  Container,
  Font,
  Head,
  Hr,
  Html,
  Img,
  Link,
  Preview,
  Row,
  Section,
  Text,
} from '@react-email/components';

interface OfficialResponseProps {
  recipientName: string;
  petitionTitle: string;
  responseTitle: string;
  responseExcerpt: string;
  responseUrl: string;
  ministry?: string;
  trackingPixelUrl?: string;
  unsubscribeUrl?: string;
}

export default function OfficialResponseTemplate({
  recipientName,
  petitionTitle,
  responseTitle,
  responseExcerpt,
  responseUrl,
  ministry,
  trackingPixelUrl,
  unsubscribeUrl,
}: OfficialResponseProps) {
  return (
    <Html>
      <Head>
        <Font
          fontFamily="Segoe UI"
          fallbackFontFamily="Verdana"
          webFont={{
            url: 'https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap',
            format: 'woff2',
          }}
        />
      </Head>
      <Preview>Official response received for your petition!</Preview>
      <Body style={main}>
        <Container style={container}>
          <Section style={box}>
            {/* Header */}
            <Row>
              <Section style={{ textAlign: 'center' as const }}>
                <Text style={heading1}>📮 Official Response Received</Text>
              </Section>
            </Row>

            <Hr style={hr} />

            {/* Main Content */}
            <Text style={paragraph}>
              Hi {recipientName},
            </Text>

            <Text style={paragraph}>
              Great news! The government has officially responded to your petition. 
              Read their complete response below.
            </Text>

            {/* Response Details Box */}
            <Section style={responseBox}>
              <Text style={responseLabel}>Petition</Text>
              <Text style={responseValue}>{petitionTitle}</Text>

              {ministry && (
                <>
                  <Text style={responseLabel}>Ministry Response</Text>
                  <Text style={responseValue}>{ministry}</Text>
                </>
              )}

              <Text style={responseLabel}>Response Title</Text>
              <Text style={responseValue}>{responseTitle}</Text>

              <Hr style={divider} />

              <Text style={responseLabel}>Response Excerpt</Text>
              <Text style={responseExcerpt}>{responseExcerpt}</Text>
            </Section>

            <Section style={buttonContainer}>
              <Button style={button} href={responseUrl}>
                Read Full Response
              </Button>
            </Section>

            <Text style={paragraph}>
              What can you do now?
            </Text>

            <ul style={list}>
              <li>
                <Text style={listItem}>
                  <strong>Share this response</strong> with your supporters
                </Text>
              </li>
              <li>
                <Text style={listItem}>
                  <strong>Post an update</strong> on your petition page with your thoughts
                </Text>
              </li>
              <li>
                <Text style={listItem}>
                  <strong>Continue the conversation</strong> by engaging with your community
                </Text>
              </li>
            </ul>

            <Hr style={hr} />

            <Text style={paragraph}>
              Thank you for using Change Liberia to make your voice heard and drive positive change!
            </Text>

            <Text style={paragraph}>
              Questions? Contact us at{' '}
              <Link href="mailto:support@changeliberia.org" style={footerLink}>
                support@changeliberia.org
              </Link>
            </Text>

            {/* Footer */}
            <Hr style={hr} />

            <Text style={footer}>
              © {new Date().getFullYear()} Change Liberia. Democracy in action.
            </Text>

            {unsubscribeUrl && (
              <Text style={footer}>
                <Link href={unsubscribeUrl} style={footerLink}>
                  Manage email preferences
                </Link>
              </Text>
            )}

            {trackingPixelUrl && (
              <Img src={trackingPixelUrl} alt="" width="1" height="1" />
            )}
          </Section>
        </Container>
      </Body>
    </Html>
  );
}

const main = {
  backgroundColor: '#f9fafb',
  fontFamily:
    '-apple-system,BlinkMacSystemFont,"Segoe UI","Roboto","Oxygen-Sans","Ubuntu","Cantarell","Helvetica Neue",sans-serif',
};

const container = {
  margin: '0 auto',
  padding: '20px 0 48px',
  marginBottom: '64px',
};

const box = {
  padding: '0 48px',
};

const heading1 = {
  color: '#1f2937',
  fontSize: '32px',
  fontWeight: '700',
  margin: '24px 0 16px 0',
  padding: '0',
  lineHeight: '1.3',
};

const paragraph = {
  color: '#4b5563',
  fontSize: '15px',
  lineHeight: '1.5',
  margin: '16px 0',
};

const hr = {
  borderColor: '#e5e7eb',
  margin: '24px 0',
};

const divider = {
  borderColor: '#d1d5db',
  margin: '16px 0',
};

const responseBox = {
  backgroundColor: '#fff8f0',
  border: '2px solid #fdba74',
  borderRadius: '6px',
  padding: '20px',
  marginBottom: '24px',
};

const responseLabel = {
  color: '#92400e',
  fontSize: '11px',
  fontWeight: '700',
  textTransform: 'uppercase' as const,
  letterSpacing: '0.5px',
  margin: '0 0 6px 0',
};

const responseValue = {
  color: '#1f2937',
  fontSize: '15px',
  fontWeight: '600',
  margin: '0 0 12px 0',
  lineHeight: '1.4',
};

const responseExcerpt = {
  color: '#78350f',
  fontSize: '14px',
  lineHeight: '1.6',
  margin: '0',
  fontStyle: 'italic',
};

const list = {
  margin: '16px 0 16px 20px',
  padding: '0',
  listStyleType: 'disc' as const,
};

const listItem = {
  color: '#4b5563',
  fontSize: '15px',
  lineHeight: '1.5',
  margin: '8px 0',
};

const buttonContainer = {
  textAlign: 'center' as const,
  margin: '32px 0',
};

const button = {
  backgroundColor: '#f59e0b',
  borderRadius: '6px',
  color: '#fff',
  fontSize: '15px',
  fontWeight: '600',
  lineHeight: '100%',
  textDecoration: 'none',
  textAlign: 'center' as const,
  display: 'block',
  padding: '12px 32px',
};

const footer = {
  color: '#6b7280',
  fontSize: '13px',
  lineHeight: '1.5',
  margin: '12px 0',
};

const footerLink = {
  color: '#10b981',
  textDecoration: 'none',
};
