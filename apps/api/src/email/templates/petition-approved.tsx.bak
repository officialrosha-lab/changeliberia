import {
  Body,
  Button,
  Container,
  Font,
  Head,
  Hr,
  Html,
  Img,
  Link,
  Preview,
  Row,
  Section,
  Text,
} from '@react-email/components';

interface PetitionApprovedProps {
  creatorName: string;
  petitionTitle: string;
  petitionUrl: string;
  petitionCategory?: string;
  trackingPixelUrl?: string;
  unsubscribeUrl?: string;
}

export default function PetitionApprovedTemplate({
  creatorName,
  petitionTitle,
  petitionUrl,
  petitionCategory,
  trackingPixelUrl,
  unsubscribeUrl,
}: PetitionApprovedProps) {
  return (
    <Html>
      <Head>
        <Font
          fontFamily="Segoe UI"
          fallbackFontFamily="Verdana"
          webFont={{
            url: 'https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap',
            format: 'woff2',
          }}
        />
      </Head>
      <Preview>Your petition has been approved!</Preview>
      <Body style={main}>
        <Container style={container}>
          <Section style={box}>
            {/* Header */}
            <Row>
              <Section style={{ textAlign: 'center' as const }}>
                <Text style={heading1}>🎉 Your Petition Has Been Approved!</Text>
              </Section>
            </Row>

            <Hr style={hr} />

            {/* Main Content */}
            <Text style={paragraph}>
              Hi {creatorName},
            </Text>

            <Text style={paragraph}>
              Great news! Your petition has been reviewed and approved. It's now live and ready 
              for Change Liberia community to see and sign.
            </Text>

            {/* Petition Details Box */}
            <Section style={detailsBox}>
              <Text style={detailsLabel}>Petition Title</Text>
              <Text style={detailsValue}>{petitionTitle}</Text>

              {petitionCategory && (
                <>
                  <Text style={detailsLabel}>Category</Text>
                  <Text style={detailsValue}>{petitionCategory}</Text>
                </>
              )}
            </Section>

            <Section style={buttonContainer}>
              <Button style={button} href={petitionUrl}>
                View Your Petition
              </Button>
            </Section>

            <Text style={paragraph}>
              What's next?
            </Text>

            <ul style={list}>
              <li>
                <Text style={listItem}>
                  <strong>Share it</strong> - Spread the word on social media and with your network
                </Text>
              </li>
              <li>
                <Text style={listItem}>
                  <strong>Post updates</strong> - Keep supporters informed about progress
                </Text>
              </li>
              <li>
                <Text style={listItem}>
                  <strong>Watch signatures grow</strong> - See real-time signature counts
                </Text>
              </li>
              <li>
                <Text style={listItem}>
                  <strong>Reach 1,000 signatures</strong> - At this milestone, your petition will be delivered to government
                </Text>
              </li>
            </ul>

            <Hr style={hr} />

            <Text style={paragraph}>
              Need help? Check out our{' '}
              <Link href="https://changeliberia.org/guide" style={footerLink}>
                creator guide
              </Link>
              {' '}or contact{' '}
              <Link href="mailto:support@changeliberia.org" style={footerLink}>
                support@changeliberia.org
              </Link>
            </Text>

            {/* Footer */}
            <Hr style={hr} />

            <Text style={footer}>
              © {new Date().getFullYear()} Change Liberia. Every voice matters.
            </Text>

            {unsubscribeUrl && (
              <Text style={footer}>
                <Link href={unsubscribeUrl} style={footerLink}>
                  Manage email preferences
                </Link>
              </Text>
            )}

            {trackingPixelUrl && (
              <Img src={trackingPixelUrl} alt="" width="1" height="1" />
            )}
          </Section>
        </Container>
      </Body>
    </Html>
  );
}

const main = {
  backgroundColor: '#f9fafb',
  fontFamily:
    '-apple-system,BlinkMacSystemFont,"Segoe UI","Roboto","Oxygen-Sans","Ubuntu","Cantarell","Helvetica Neue",sans-serif',
};

const container = {
  margin: '0 auto',
  padding: '20px 0 48px',
  marginBottom: '64px',
};

const box = {
  padding: '0 48px',
};

const heading1 = {
  color: '#1f2937',
  fontSize: '32px',
  fontWeight: '700',
  margin: '24px 0 16px 0',
  padding: '0',
  lineHeight: '1.3',
};

const paragraph = {
  color: '#4b5563',
  fontSize: '15px',
  lineHeight: '1.5',
  margin: '16px 0',
};

const hr = {
  borderColor: '#e5e7eb',
  margin: '24px 0',
};

const detailsBox = {
  backgroundColor: '#f0fdf4',
  border: '1px solid #dcfce7',
  borderRadius: '6px',
  padding: '16px',
  marginBottom: '24px',
};

const detailsLabel = {
  color: '#6b7280',
  fontSize: '12px',
  fontWeight: '600',
  textTransform: 'uppercase' as const,
  letterSpacing: '0.5px',
  margin: '0 0 4px 0',
};

const detailsValue = {
  color: '#1f2937',
  fontSize: '15px',
  fontWeight: '600',
  margin: '0 0 12px 0',
};

const buttonContainer = {
  textAlign: 'center' as const,
  margin: '32px 0',
};

const button = {
  backgroundColor: '#10b981',
  borderRadius: '6px',
  color: '#fff',
  fontSize: '15px',
  fontWeight: '600',
  lineHeight: '100%',
  textDecoration: 'none',
  textAlign: 'center' as const,
  display: 'block',
  padding: '12px 32px',
};

const list = {
  margin: '16px 0 16px 20px',
  padding: '0',
  listStyleType: 'disc' as const,
};

const listItem = {
  color: '#4b5563',
  fontSize: '15px',
  lineHeight: '1.5',
  margin: '8px 0',
};

const footer = {
  color: '#6b7280',
  fontSize: '13px',
  lineHeight: '1.5',
  margin: '12px 0',
};

const footerLink = {
  color: '#10b981',
  textDecoration: 'none',
};
