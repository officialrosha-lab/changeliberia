import React from 'react';
import {
  Body,
  Button,
  Column,
  Container,
  Font,
  Head,
  Hr,
  Html,
  Img,
  Link,
  Preview,
  Row,
  Section,
  Text,
} from '@react-email/components';

interface WelcomeEmailProps {
  recipientName: string;
  appUrl: string;
  trackingPixelUrl?: string;
  unsubscribeUrl?: string;
}

const baseUrl = process.env.VERCEL_URL
  ? `https://${process.env.VERCEL_URL}`
  : 'http://localhost:3000';

export default function WelcomeEmail({
  recipientName,
  appUrl,
  trackingPixelUrl,
  unsubscribeUrl,
}: WelcomeEmailProps) {
  return (
    <Html>
      <Head>
        <Font
          fontFamily="Segoe UI"
          fallbackFontFamily="Verdana"
          webFont={{
            url: 'https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap',
            format: 'woff2',
          }}
        />
      </Head>
      <Preview>Welcome to Change Liberia - Your voice matters!</Preview>
      <Body style={main}>
        <Container style={container}>
          <Section style={box}>
            {/* Header */}
            <Row>
              <Column align="center">
                <Text style={heading1}>Welcome to Change Liberia</Text>
              </Column>
            </Row>

            <Hr style={hr} />

            {/* Main Content */}
            <Text style={paragraph}>
              Hi {recipientName},
            </Text>

            <Text style={paragraph}>
              Thank you for joining Change Liberia! We're excited to have you on board. 
              Together, we can create meaningful change for our nation through petitions, 
              community action, and direct government engagement.
            </Text>

            <Section style={buttonContainer}>
              <Button style={button} href={appUrl}>
                Get Started
              </Button>
            </Section>

            <Text style={paragraph}>
              Here's what you can do:
            </Text>

            <ul style={list}>
              <li>
                <Text style={listItem}>
                  <strong>Start a Petition</strong> - Share your concerns and rally support
                </Text>
              </li>
              <li>
                <Text style={listItem}>
                  <strong>Sign Petitions</strong> - Support causes you believe in
                </Text>
              </li>
              <li>
                <Text style={listItem}>
                  <strong>Track Progress</strong> - See petitions being delivered to government
                </Text>
              </li>
            </ul>

            <Hr style={hr} />

            {/* Footer */}
            <Text style={footer}>
              Change Liberia is a platform for citizen engagement and democratic participation.
            </Text>

            <Text style={footer}>
              Questions? Contact us at{' '}
              <Link href="mailto:support@changeliberia.org" style={footerLink}>
                support@changeliberia.org
              </Link>
            </Text>

            {unsubscribeUrl && (
              <Text style={footer}>
                <Link href={unsubscribeUrl} style={footerLink}>
                  Unsubscribe from emails
                </Link>
              </Text>
            )}

            {trackingPixelUrl && (
              <Img src={trackingPixelUrl} alt="" width="1" height="1" />
            )}
          </Section>
        </Container>
      </Body>
    </Html>
  );
}

const main = {
  backgroundColor: '#f9fafb',
  fontFamily:
    '-apple-system,BlinkMacSystemFont,"Segoe UI","Roboto","Oxygen-Sans","Ubuntu","Cantarell","Helvetica Neue",sans-serif',
};

const container = {
  margin: '0 auto',
  padding: '20px 0 48px',
  marginBottom: '64px',
};

const box = {
  padding: '0 48px',
};

const heading1 = {
  color: '#1f2937',
  fontSize: '32px',
  fontWeight: '700',
  margin: '24px 0 16px 0',
  padding: '0',
  lineHeight: '1.3',
};

const paragraph = {
  color: '#4b5563',
  fontSize: '15px',
  lineHeight: '1.5',
  margin: '16px 0',
};

const hr = {
  borderColor: '#e5e7eb',
  margin: '24px 0',
};

const buttonContainer = {
  textAlign: 'center' as const,
  margin: '32px 0',
};

const button = {
  backgroundColor: '#10b981',
  borderRadius: '6px',
  color: '#fff',
  fontSize: '15px',
  fontWeight: '600',
  lineHeight: '100%',
  textDecoration: 'none',
  textAlign: 'center' as const,
  display: 'block',
  padding: '12px 32px',
  marginBottom: '32px',
};

const list = {
  margin: '16px 0 16px 20px',
  padding: '0',
  listStyleType: 'disc' as const,
};

const listItem = {
  color: '#4b5563',
  fontSize: '15px',
  lineHeight: '1.5',
  margin: '8px 0',
};

const footer = {
  color: '#6b7280',
  fontSize: '13px',
  lineHeight: '1.5',
  margin: '12px 0',
};

const footerLink = {
  color: '#10b981',
  textDecoration: 'none',
};
