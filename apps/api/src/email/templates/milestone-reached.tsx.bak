import {
  Body,
  Button,
  Container,
  Font,
  Head,
  Hr,
  Html,
  Img,
  Link,
  Preview,
  Row,
  Section,
  Text,
} from '@react-email/components';

interface PetitionMilestoneProps {
  creatorName: string;
  petitionTitle: string;
  petitionUrl: string;
  milestoneValue: number;
  currentSignatures: number;
  trackingPixelUrl?: string;
  unsubscribeUrl?: string;
}

function getMilestoneMessage(milestone: number): string {
  const messages: Record<number, string> = {
    10: 'Getting started! Every signature counts.',
    50: 'Growing strong! Share your petition to reach more people.',
    100: 'Momentum is building! Keep pushing forward.',
    500: 'Incredible growth! Your petition is gaining serious traction.',
    1000: 'You have reached 1,000 signatures! Your petition will now be delivered to government.',
  };
  return messages[milestone] || 'Great progress! Keep the momentum going!';
}

export default function PetitionMilestoneTemplate({
  creatorName,
  petitionTitle,
  petitionUrl,
  milestoneValue,
  currentSignatures,
  trackingPixelUrl,
  unsubscribeUrl,
}: PetitionMilestoneProps) {
  const milestoneMessage = getMilestoneMessage(milestoneValue);\n\n  return (
    <Html>
      <Head>
        <Font
          fontFamily="Segoe UI"
          fallbackFontFamily="Verdana"
          webFont={{
            url: 'https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap',
            format: 'woff2',
          }}
        />
      </Head>
      <Preview>Your petition reached {milestoneValue} signatures!</Preview>
      <Body style={main}>
        <Container style={container}>
          <Section style={box}>
            <Row>
              <Section style={{ textAlign: 'center' as const }}>
                <Text style={heading1}>Milestone Reached!</Text>
              </Section>
            </Row>

            <Hr style={hr} />

            <Text style={paragraph}>Hi {creatorName},</Text>

            <Text style={paragraph}>
              Congratulations! Your petition has reached{' '}\n              <strong>{milestoneValue} signatures</strong>!
            </Text>

            <Section style={milestoneBox}>
              <Row>
                <Section style={{ width: '100%', textAlign: 'center' as const }}>
                  <Text style={milestoneNumber}>{currentSignatures}</Text>
                  <Text style={milestoneLabel}>Signatures</Text>
                </Section>
              </Row>
              <Text style={milestoneMessageStyle}>{milestoneMessage}</Text>
            </Section>

            <Text style={paragraph}>
              Keep up the momentum! Every signature represents a voice calling for change.
            </Text>

            <Section style={buttonContainer}>
              <Button style={button} href={petitionUrl}>
                View Your Petition
              </Button>
            </Section>

            {milestoneValue >= 1000 && (
              <Section style={alertBox}>
                <Text style={alertTitle}>Government Delivery Ready</Text>
                <Text style={alertText}>
                  Your petition has reached 1,000 signatures and is eligible for delivery to government
                  officials. Our team will review and process this submission soon.
                </Text>
              </Section>
            )}

            <Text style={paragraph}>
              Share this milestone with your supporters:
            </Text>

            <ul style={list}>
              <li>
                <Text style={listItem}>Post on social media</Text>
              </li>
              <li>
                <Text style={listItem}>Send updates to your supporters</Text>
              </li>
              <li>
                <Text style={listItem}>Share the petition link with community leaders</Text>
              </li>
            </ul>

            <Hr style={hr} />

            <Text style={paragraph}>
              Questions? Contact us at{' '}\n              <Link href="mailto:support@changeliberia.org" style={footerLink}>\n                support@changeliberia.org\n              </Link>\n            </Text>

            <Hr style={hr} />

            <Text style={footer}>
              © {new Date().getFullYear()} Change Liberia. Every voice matters.
            </Text>

            {unsubscribeUrl && (
              <Text style={footer}>
                <Link href={unsubscribeUrl} style={footerLink}>
                  Manage email preferences
                </Link>
              </Text>
            )}

            {trackingPixelUrl && (
              <Img src={trackingPixelUrl} alt="" width="1" height="1" />
            )}
          </Section>
        </Container>
      </Body>
    </Html>
  );
}

const main = {
  backgroundColor: '#f9fafb',
  fontFamily:
    '-apple-system,BlinkMacSystemFont,"Segoe UI","Roboto","Oxygen-Sans","Ubuntu","Cantarell","Helvetica Neue",sans-serif',
};

const container = {
  margin: '0 auto',
  padding: '20px 0 48px',
  marginBottom: '64px',
};

const box = {
  padding: '0 48px',
};

const heading1 = {
  color: '#1f2937',
  fontSize: '32px',
  fontWeight: '700',
  margin: '24px 0 16px 0',
  padding: '0',
  lineHeight: '1.3',
};

const paragraph = {
  color: '#4b5563',
  fontSize: '15px',
  lineHeight: '1.5',
  margin: '16px 0',
};

const hr = {
  borderColor: '#e5e7eb',
  margin: '24px 0',
};

const milestoneBox = {
  backgroundColor: '#f0f9ff',
  border: '2px solid #7dd3fc',
  borderRadius: '6px',
  padding: '24px',
  marginBottom: '24px',
  textAlign: 'center' as const,
};

const milestoneNumber = {
  color: '#0369a1',
  fontSize: '48px',
  fontWeight: '700',
  margin: '0 0 8px 0',
};

const milestoneLabel = {
  color: '#0c4a6e',
  fontSize: '14px',
  fontWeight: '600',
  textTransform: 'uppercase' as const,
  letterSpacing: '0.5px',
  margin: '0 0 12px 0',
};

const milestoneMessageStyle = {
  color: '#0c4a6e',
  fontSize: '15px',
  fontWeight: '500',
  margin: '0',
  lineHeight: '1.5',
};

const alertBox = {
  backgroundColor: '#f0fdf4',
  border: '1px solid #dcfce7',
  borderRadius: '6px',
  padding: '16px',
  marginBottom: '24px',
};

const alertTitle = {
  color: '#166534',
  fontSize: '14px',
  fontWeight: '600',
  margin: '0 0 8px 0',
};

const alertText = {
  color: '#15803d',
  fontSize: '14px',
  lineHeight: '1.5',
  margin: '0',
};

const buttonContainer = {
  textAlign: 'center' as const,
  margin: '32px 0',
};

const button = {
  backgroundColor: '#10b981',
  borderRadius: '6px',
  color: '#fff',
  fontSize: '15px',
  fontWeight: '600',
  lineHeight: '100%',
  textDecoration: 'none',
  textAlign: 'center' as const,
  display: 'block',
  padding: '12px 32px',
};

const list = {
  margin: '16px 0 16px 20px',
  padding: '0',
  listStyleType: 'disc' as const,
};

const listItem = {
  color: '#4b5563',
  fontSize: '15px',
  lineHeight: '1.5',
  margin: '8px 0',
};

const footer = {
  color: '#6b7280',
  fontSize: '13px',
  lineHeight: '1.5',
  margin: '12px 0',
};

const footerLink = {
  color: '#10b981',
  textDecoration: 'none',
};
