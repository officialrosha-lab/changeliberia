import {
  Body,
  Button,
  Container,
  Font,
  Head,
  Hr,
  Html,
  Img,
  Link,
  Preview,
  Row,
  Section,
  Text,
} from '@react-email/components';

interface GovernmentSubmissionProps {
  creatorName: string;
  petitionTitle: string;
  signatureCount: number;
  petitionUrl: string;
  category?: string;
  trackingPixelUrl?: string;
  unsubscribeUrl?: string;
}

export default function GovernmentSubmissionTemplate({
  creatorName,
  petitionTitle,
  signatureCount,
  petitionUrl,
  category,
  trackingPixelUrl,
  unsubscribeUrl,
}: GovernmentSubmissionProps) {
  return (
    <Html>
      <Head>
        <Font
          fontFamily="Segoe UI"
          fallbackFontFamily="Verdana"
          webFont={{
            url: 'https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap',
            format: 'woff2',
          }}
        />
      </Head>
      <Preview>Your petition has been submitted to government!</Preview>
      <Body style={main}>
        <Container style={container}>
          <Section style={box}>
            {/* Header */}
            <Row>
              <Section style={{ textAlign: 'center' as const }}>
                <Text style={heading1}>📬 Your Petition Delivered to Government</Text>
              </Section>
            </Row>

            <Hr style={hr} />

            {/* Main Content */}
            <Text style={paragraph}>
              Hi {creatorName},
            </Text>

            <Text style={paragraph}>
              Excellent news! Your petition has reached 1,000 signatures and has been officially 
              submitted to the relevant government ministry or agency. This is a significant milestone 
              in your campaign!
            </Text>

            {/* Petition Details Box */}
            <Section style={detailsBox}>
              <Text style={detailsLabel}>Petition</Text>
              <Text style={detailsValue}>{petitionTitle}</Text>

              <Text style={detailsLabel}>Signatures Collected</Text>
              <Text style={detailsValue}>{signatureCount.toLocaleString()}</Text>

              {category && (
                <>
                  <Text style={detailsLabel}>Category</Text>
                  <Text style={detailsValue}>{category}</Text>
                </>
              )}
            </Section>

            <Text style={paragraph}>
              What happens next?
            </Text>

            <ul style={list}>
              <li>
                <Text style={listItem}>
                  <strong>Government review</strong> - Officials review your petition
                </Text>
              </li>
              <li>
                <Text style={listItem}>
                  <strong>Formal response</strong> - You'll receive an official response (typically within 30-60 days)
                </Text>
              </li>
              <li>
                <Text style={listItem}>
                  <strong>Keep the momentum</strong> - Continue sharing updates with your supporters
                </Text>
              </li>
              <li>
                <Text style={listItem}>
                  <strong>Stay tuned</strong> - We'll notify you when a government response is received
                </Text>
              </li>
            </ul>

            <Section style={buttonContainer}>
              <Button style={button} href={petitionUrl}>
                View Your Petition
              </Button>
            </Section>

            <Section style={infoBox}>
              <Text style={infoTitle}>💡 Tip: Keep Your Community Engaged</Text>
              <Text style={infoText}>
                Share updates with your supporters about the government submission. 
                The more visible your petition is, the greater its impact will be.
              </Text>
            </Section>

            <Hr style={hr} />

            <Text style={paragraph}>
              Questions about the process? Contact us at{' '}
              <Link href="mailto:support@changeliberia.org" style={footerLink}>
                support@changeliberia.org
              </Link>
            </Text>

            {/* Footer */}
            <Hr style={hr} />

            <Text style={footer}>
              © {new Date().getFullYear()} Change Liberia. Empowering citizens to create change.
            </Text>

            {unsubscribeUrl && (
              <Text style={footer}>
                <Link href={unsubscribeUrl} style={footerLink}>
                  Manage email preferences
                </Link>
              </Text>
            )}

            {trackingPixelUrl && (
              <Img src={trackingPixelUrl} alt="" width="1" height="1" />
            )}
          </Section>
        </Container>
      </Body>
    </Html>
  );
}

const main = {
  backgroundColor: '#f9fafb',
  fontFamily:
    '-apple-system,BlinkMacSystemFont,"Segoe UI","Roboto","Oxygen-Sans","Ubuntu","Cantarell","Helvetica Neue",sans-serif',
};

const container = {
  margin: '0 auto',
  padding: '20px 0 48px',
  marginBottom: '64px',
};

const box = {
  padding: '0 48px',
};

const heading1 = {
  color: '#1f2937',
  fontSize: '32px',
  fontWeight: '700',
  margin: '24px 0 16px 0',
  padding: '0',
  lineHeight: '1.3',
};

const paragraph = {
  color: '#4b5563',
  fontSize: '15px',
  lineHeight: '1.5',
  margin: '16px 0',
};

const hr = {
  borderColor: '#e5e7eb',
  margin: '24px 0',
};

const detailsBox = {
  backgroundColor: '#f3f4f6',
  border: '1px solid #d1d5db',
  borderRadius: '6px',
  padding: '16px',
  marginBottom: '24px',
};

const detailsLabel = {
  color: '#6b7280',
  fontSize: '12px',
  fontWeight: '600',
  textTransform: 'uppercase' as const,
  letterSpacing: '0.5px',
  margin: '0 0 4px 0',
};

const detailsValue = {
  color: '#1f2937',
  fontSize: '15px',
  fontWeight: '600',
  margin: '0 0 12px 0',
};

const list = {
  margin: '16px 0 16px 20px',
  padding: '0',
  listStyleType: 'disc' as const,
};

const listItem = {
  color: '#4b5563',
  fontSize: '15px',
  lineHeight: '1.5',
  margin: '8px 0',
};

const infoBox = {
  backgroundColor: '#eff6ff',
  border: '1px solid #bfdbfe',
  borderRadius: '6px',
  padding: '16px',
  marginBottom: '24px',
};

const infoTitle = {
  color: '#1e40af',
  fontSize: '14px',
  fontWeight: '600',
  margin: '0 0 8px 0',
};

const infoText = {
  color: '#1e3a8a',
  fontSize: '14px',
  lineHeight: '1.5',
  margin: '0',
};

const buttonContainer = {
  textAlign: 'center' as const,
  margin: '32px 0',
};

const button = {
  backgroundColor: '#6366f1',
  borderRadius: '6px',
  color: '#fff',
  fontSize: '15px',
  fontWeight: '600',
  lineHeight: '100%',
  textDecoration: 'none',
  textAlign: 'center' as const,
  display: 'block',
  padding: '12px 32px',
};

const footer = {
  color: '#6b7280',
  fontSize: '13px',
  lineHeight: '1.5',
  margin: '12px 0',
};

const footerLink = {
  color: '#10b981',
  textDecoration: 'none',
};
