import {
  Body,
  Button,
  Column,
  Container,
  Font,
  Head,
  Hr,
  Html,
  Img,
  Link,
  Preview,
  Row,
  Section,
  Text,
} from '@react-email/components';

interface VerifyEmailProps {
  recipientName: string;
  verifyUrl: string;
  expiresIn?: string;
  trackingPixelUrl?: string;
  unsubscribeUrl?: string;
}

export default function VerifyEmailTemplate({
  recipientName,
  verifyUrl,
  expiresIn = '24 hours',
  trackingPixelUrl,
  unsubscribeUrl,
}: VerifyEmailProps) {
  return (
    <Html>
      <Head>
        <Font
          fontFamily="Segoe UI"
          fallbackFontFamily="Verdana"
          webFont={{
            url: 'https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap',
            format: 'woff2',
          }}
        />
      </Head>
      <Preview>Verify your email address</Preview>
      <Body style={main}>
        <Container style={container}>
          <Section style={box}>
            {/* Header */}
            <Row>
              <Column align="center">
                <Text style={heading1}>Verify Your Email</Text>
              </Column>
            </Row>

            <Hr style={hr} />

            {/* Main Content */}
            <Text style={paragraph}>
              Hi {recipientName},
            </Text>

            <Text style={paragraph}>
              Thank you for signing up! Please verify your email address to activate your account 
              and start participating in Change Liberia.
            </Text>

            <Section style={buttonContainer}>
              <Button style={button} href={verifyUrl}>
                Verify Email Address
              </Button>
            </Section>

            <Text style={codeSection}>
              Or copy this link in your browser:
            </Text>

            <Text style={codeBlock}>
              {verifyUrl}
            </Text>

            <Text style={expiryText}>
              This link expires in {expiresIn}.
            </Text>

            <Hr style={hr} />

            <Text style={paragraph}>
              Didn't request this email? You can safely ignore it.
            </Text>

            <Text style={paragraph}>
              Having trouble? Contact us at{' '}
              <Link href="mailto:support@changeliberia.org" style={footerLink}>
                support@changeliberia.org
              </Link>
            </Text>

            {/* Footer */}
            <Hr style={hr} />

            <Text style={footer}>
              © {new Date().getFullYear()} Change Liberia. All rights reserved.
            </Text>

            {unsubscribeUrl && (
              <Text style={footer}>
                <Link href={unsubscribeUrl} style={footerLink}>
                  Manage email preferences
                </Link>
              </Text>
            )}

            {trackingPixelUrl && (
              <Img src={trackingPixelUrl} alt="" width="1" height="1" />
            )}
          </Section>
        </Container>
      </Body>
    </Html>
  );
}

const main = {
  backgroundColor: '#f9fafb',
  fontFamily:
    '-apple-system,BlinkMacSystemFont,"Segoe UI","Roboto","Oxygen-Sans","Ubuntu","Cantarell","Helvetica Neue",sans-serif',
};

const container = {
  margin: '0 auto',
  padding: '20px 0 48px',
  marginBottom: '64px',
};

const box = {
  padding: '0 48px',
};

const heading1 = {
  color: '#1f2937',
  fontSize: '32px',
  fontWeight: '700',
  margin: '24px 0 16px 0',
  padding: '0',
  lineHeight: '1.3',
};

const paragraph = {
  color: '#4b5563',
  fontSize: '15px',
  lineHeight: '1.5',
  margin: '16px 0',
};

const hr = {
  borderColor: '#e5e7eb',
  margin: '24px 0',
};

const buttonContainer = {
  textAlign: 'center' as const,
  margin: '32px 0',
};

const button = {
  backgroundColor: '#10b981',
  borderRadius: '6px',
  color: '#fff',
  fontSize: '15px',
  fontWeight: '600',
  lineHeight: '100%',
  textDecoration: 'none',
  textAlign: 'center' as const,
  display: 'block',
  padding: '12px 32px',
};

const codeSection = {
  color: '#4b5563',
  fontSize: '13px',
  fontWeight: '600',
  margin: '24px 0 8px 0',
};

const codeBlock = {
  backgroundColor: '#f3f4f6',
  border: '1px solid #e5e7eb',
  borderRadius: '4px',
  color: '#374151',
  fontSize: '12px',
  fontFamily: 'monospace',
  lineHeight: '1.4',
  padding: '12px',
  marginBottom: '16px',
  wordBreak: 'break-all' as const,
};

const expiryText = {
  color: '#9ca3af',
  fontSize: '13px',
  margin: '16px 0',
  fontStyle: 'italic',
};

const footer = {
  color: '#6b7280',
  fontSize: '13px',
  lineHeight: '1.5',
  margin: '12px 0',
};

const footerLink = {
  color: '#10b981',
  textDecoration: 'none',
};
