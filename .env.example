# Change Liberia - Environment Variables Configuration
# Local dev defaults. For production, set NODE_ENV=production, strong JWT_SECRET,
# CORS_ORIGIN=https://your-frontend-host, ID_DOCUMENT_PUBLIC_BASE_URL=https://your-api-host,
# ENABLE_SWAGGER=false, and real credentials on the platform (not in git).

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/verified_liberian_voices"

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET="super-secret"
JWT_EXPIRES_IN="7d"

# ============================================================================
# GOOGLE OAUTH INTEGRATION
# ============================================================================
# Get credentials from https://console.cloud.google.com
# 1. Create OAuth 2.0 Client ID (Web application type)
# 2. Add authorized redirect URI: http://localhost:3001/auth/google/callback
# 3. Copy Client ID and Client Secret below
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_CALLBACK_URL="http://localhost:3001/auth/google/callback"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""  # Same as GOOGLE_OAUTH_CLIENT_ID, used by frontend

# ============================================================================
# VERIFICATION & CAPTCHA
# ============================================================================
OTP_PROVIDER="mock"
CAPTCHA_PROVIDER="mock"
TURNSTILE_SECRET_KEY=""
HCAPTCHA_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# ============================================================================
# FRAUD DETECTION
# ============================================================================
FRAUD_RISK_ALERT_THRESHOLD="0.35"

# ============================================================================
# SMS/NOTIFICATIONS (Twilio)
# ============================================================================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ============================================================================
# STRIPE INTEGRATION (Phase 12.1)
# ============================================================================
STRIPE_API_KEY="sk_test_"
STRIPE_WEBHOOK_SECRET="whsec_test_"

# ============================================================================
# EMAIL CONFIGURATION (Phase 12.3)
# ============================================================================
EMAIL_PROVIDER="development"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@liberianvoices.org"
EMAIL_REPLY_TO="support@liberianvoices.org"

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
API_URL_INTERNAL="http://api:4000/api/v1"

# ============================================================================
# CORS & APPLICATION
# ============================================================================
CORS_ORIGIN="http://localhost:3000"
ID_DOCUMENT_PUBLIC_BASE_URL="http://localhost:4000"
APP_URL="http://localhost:4000"

# ============================================================================
# DOCUMENTATION
# ============================================================================
ENABLE_SWAGGER="true"

# ============================================================================
# FILE UPLOADS
# ============================================================================
ID_DOCUMENT_UPLOAD_DIR=""

# ============================================================================
# FACEBOOK INTEGRATION (Phase 8)
# ============================================================================
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_PIXEL_ID=""

# ============================================================================
# ENVIRONMENT NOTES
# ============================================================================
# Development: Use test keys, mock providers
# Production: Use live keys, real SMTP/SendGrid, enable rate limiting
# Staging: Test with real integrations, monitor logs
